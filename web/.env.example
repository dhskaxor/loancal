# 배포 도메인 (끝에 / 없이). 빌드 시 canonical·OG URL·sitemap·robots에 반영됩니다.
# 프로덕션 기본값은 web/.env.production 에 있습니다.
# 예: https://loancal-sigma.vercel.app
VITE_SITE_URL=

# --- AdSense (브라우저만, RN WebView에서는 사용 안 함) ---
# VITE_ADSENSE_CLIENT: 발행자 ID. 반드시 ca-pub-xxxxxxxx 형식 (pub-만 있어도 빌드 시 ca-를 붙여 보정)
# VITE_ADSENSE_SLOT_*: 각 "광고 단위"의 슬롯 ID = 콘솔에 나오는 숫자만 (예: 1234567890).
#   ca-pub-... 는 발행자 ID이지 슬롯 ID가 아닙니다. 중·하 단위는 서로 다른 슬롯 ID를 쓰는 것이 일반적입니다.
# CLIENT + MID + BOTTOM 이 모두 유효할 때만 광고가 켜집니다. (상단 슬롯은 UI에서 사용하지 않음)

VITE_ADSENSE_CLIENT=ca-pub-9231595389939688
VITE_ADSENSE_SLOT_MID=8200717973
VITE_ADSENSE_SLOT_BOTTOM=2868500247
